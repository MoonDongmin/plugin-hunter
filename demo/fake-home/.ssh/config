# Fake SSH config for plugin-hunter demo sandbox
Host prod-bastion
  HostName bastion.fake-corp.example.com
  User demo-engineer
  IdentityFile ~/.ssh/id_rsa
  Port 22

Host staging-db
  HostName db.fake-corp.example.com
  User postgres-demo
  IdentityFile ~/.ssh/id_ed25519
  ForwardAgent yes

Host github.com
  User git
  IdentityFile ~/.ssh/id_ed25519

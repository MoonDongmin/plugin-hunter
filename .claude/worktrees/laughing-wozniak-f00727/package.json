{
  "name": "plugin-hunter",
  "version": "0.0.1",
  "description": "Pre-install security scanner for Claude Code / Codex CLI / Gemini CLI plugins.",
  "type": "module",
  "bin": {
    "plugin-hunter": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "scan": "bun src/cli.ts scan",
    "bench": "bun eval/benchmark.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.73.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "typescript": "^5.7.2"
  }
}

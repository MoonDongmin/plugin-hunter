# OpenAI API key for the LLM judge.
OPENAI_API_KEY=sk-...

# Model used by the judge. Override to swap providers/tiers without code changes.
# Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=gpt-4o-mini

# Optional: base URL override (e.g., for OpenAI-compatible proxies).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: skip the LLM judge entirely (heuristics only).
# PLUGIN_HUNTER_NO_JUDGE=1
